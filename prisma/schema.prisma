generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// MARK: - 平台角色
enum PlatformRole {
  SUPER_ADMIN
  ADMIN
  TEACHER
  STUDENT
  GUARDIAN
}

// MARK: - 用户状态
enum UserStatus {
  ACTIVE
  SUSPENDED
  DELETED
}

// MARK: - 验证码渠道
enum AuthCodeChannel {
  SMS
  EMAIL
}

// MARK: - 验证码用途
enum AuthCodePurpose {
  LOGIN_OR_REGISTER
  PHONE_BIND
  EMAIL_VERIFY
  PASSWORD_RESET
}

// MARK: - 教师就业类型
enum TeacherEmploymentType {
  FULL_TIME
  PART_TIME
}

// MARK: - 教师认证状态
enum TeacherVerificationStatus {
  PENDING
  APPROVED
  REJECTED
  SUSPENDED
}

// MARK: - 周几
enum Weekday {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

// MARK: - 年级等级
enum GradeLevel {
  KINDERGARTEN
  PRIMARY
  MIDDLE
  HIGH
  UNIVERSITY
  ADULT
}

// MARK: - 监护人关系
enum GuardianRelation {
  FATHER
  MOTHER
  GRANDPARENT
  SIBLING
  OTHER
}

// MARK: - 预约状态
enum BookingStatus {
  PENDING_ACCEPTANCE
  PENDING_PAYMENT
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  REFUNDED
  EXPIRED
}

// MARK: - 预约取消原因
enum BookingCancellationReason {
  STUDENT_NO_SHOW
  TEACHER_NO_SHOW
  STUDENT_REQUEST
  TEACHER_REQUEST
  SYSTEM_TIMEOUT
  WEATHER
  EMERGENCY
  OTHER
}

// MARK: - 支付状态
enum PaymentStatus {
  UNPAID
  PAID
  PARTIALLY_REFUNDED
  REFUNDED
  FAILED
}

// MARK: - 完课确认状态
enum BookingCompletionStatus {
  PENDING_TEACHER_RECORD
  PENDING_GUARDIAN_CONFIRM
  GUARDIAN_CONFIRMED
  AUTO_CONFIRMED
  DISPUTED
}

// MARK: - 预约异常状态
enum BookingExceptionStatus {
  NONE
  OPEN
  BLOCKING
}

// MARK: - 结算资格状态
enum SettlementReadiness {
  NOT_READY
  READY
  BLOCKED
}

// MARK: - 预约异常类型
enum BookingExceptionType {
  PAYMENT_MISMATCH
  OVERDUE_NOT_STARTED
  OVERDUE_NOT_FINISHED
  ARRIVAL_DISPUTE
  NO_FEEDBACK
  LESSON_QUALITY_DISPUTE
  DURATION_DISPUTE
  MANUAL_REPAIR_REQUIRED
}

// MARK: - 异常责任方
enum ResponsibilityType {
  TEACHER
  GUARDIAN
  PLATFORM
  UNKNOWN
}

// MARK: - 异常工单状态
enum BookingExceptionCaseStatus {
  OPEN
  WAITING_TEACHER
  WAITING_GUARDIAN
  WAITING_ADMIN
  RESOLVED
  CLOSED
}

// MARK: - 支付意图状态
enum PaymentIntentStatus {
  REQUIRES_PAYMENT
  PROCESSING
  SUCCEEDED
  FAILED
  CANCELLED
  REFUNDED
}

// MARK: - 预约占位状态
enum BookingHoldStatus {
  ACTIVE
  CONSUMED
  EXPIRED
  CANCELLED
}

// MARK: - 改约请求状态
enum RescheduleRequestStatus {
  PENDING
  ACCEPTED
  REJECTED
  CANCELLED
}

// MARK: - 货币
enum Currency {
  CNY
}

// MARK: - 钱包状态
enum WalletStatus {
  ACTIVE
  FROZEN
  CLOSED
}

// MARK: - 钱包交易类型
enum WalletTransactionType {
  TOPUP
  BOOKING_HOLD
  BOOKING_RELEASE
  BOOKING_PAYMENT
  REFUND
  PAYOUT
  WITHDRAW
  ADJUSTMENT
}

// MARK: - 账本状态
enum LedgerStatus {
  PENDING
  SETTLED
  FAILED
  REVERSED
}

// MARK: - 交易方向
enum TransactionDirection {
  IN
  OUT
}

// MARK: - 交易参考类型
enum TransactionReferenceType {
  BOOKING
  PAYMENT
  PAYOUT
  MANUAL
}

// MARK: - 课程出勤状态
enum LessonAttendanceStatus {
  SCHEDULED
  ONGOING
  COMPLETED
  STUDENT_ABSENT
  TEACHER_ABSENT
  CANCELLED
}

// MARK: - 课程证据类型
enum LessonEvidenceType {
  ARRIVAL_PHOTO
  ARRIVAL_VIDEO
  RESULT_PHOTO
  RESULT_VIDEO
  OTHER
}

// MARK: - 提现状态
enum PayoutStatus {
  PENDING
  APPROVED
  PROCESSING
  PAID
  FAILED
  CANCELLED
}

// MARK: - 提现账户类型
enum PayoutAccountType {
  ALIPAY
  WECHAT
  BANK_CARD
}

// MARK: - 凭证类型
enum CredentialType {
  TEACHING_LICENSE
  ID_CARD
  DEGREE
  CERTIFICATE
  NO_CRIMINAL_RECORD
  OTHER
}

// MARK: - 文档审核状态
enum DocumentReviewStatus {
  PENDING
  APPROVED
  REJECTED
}

// MARK: - 用户
model User {
  id                     String     @id @default(cuid())
  name                   String?
  email                  String?    @unique
  emailVerified          DateTime?  @map("email_verified")
  image                  String?
  phone                  String?    @unique
  phoneVerifiedAt        DateTime?  @map("phone_verified_at")
  realNameVerifiedAt     DateTime?  @map("real_name_verified_at")
  realNameProvider       String?    @map("real_name_provider")
  realNameVerifiedName   String?    @map("real_name_verified_name")
  realNameIdNumberMasked String?    @map("real_name_id_number_masked")
  status                 UserStatus @default(ACTIVE)
  timezone               String     @default("Asia/Shanghai")
  locale                 String     @default("zh-CN")
  deletedAt              DateTime?  @map("deleted_at")
  createdAt              DateTime   @default(now()) @map("created_at")
  updatedAt              DateTime   @updatedAt @map("updated_at")

  accounts                       Account[]
  authVerificationCodes          AuthVerificationCode[]
  passwordCredential             PasswordCredential?
  sessions                       Session[]
  authenticators                 Authenticator[]
  roles                          UserRole[]
  teacherProfile                 TeacherProfile?
  studentProfile                 StudentProfile?
  guardianProfile                GuardianProfile?
  addresses                      Address[]
  realNameVerificationSessions   RealNameVerificationSession[]
  wallet                         Wallet?
  walletTransactions             WalletTransaction[]           @relation("TxnCreatedBy")
  bookingsCancelled              Booking[]                     @relation("BookingCancelledBy")
  paymentIntents                 PaymentIntent[]               @relation("PaymentPayer")
  adminAuditLogs                 AdminAuditLog[]               @relation("AuditActor")
  teacherAvailabilityBlocksAdded TeacherAvailabilityBlock[]    @relation("AvailabilityBlockCreatedBy")
  teacherCredentialsReviewed     TeacherCredential[]           @relation("CredentialReviewedBy")

  @@index([status])
  @@map("users")
}

// MARK: - 密码凭证
model PasswordCredential {
  id           String   @id @default(cuid())
  userId       String   @unique @map("user_id")
  passwordHash String   @map("password_hash")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("password_credentials")
}

// MARK: - 账户
model Account {
  id                String    @id @default(cuid())
  userId            String    @map("user_id")
  type              String
  provider          String
  providerAccountId String    @map("provider_account_id")
  providerAppId     String?   @map("provider_app_id")
  unionId           String?   @map("union_id")
  openId            String?   @map("open_id")
  refresh_token     String?   @db.Text
  access_token      String?   @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?   @db.Text
  session_state     String?
  profileRaw        Json?     @map("profile_raw")
  lastLoginAt       DateTime? @map("last_login_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
  @@index([provider, unionId])
  @@index([provider, openId])
  @@map("accounts")
}

// MARK: - 验证码
model AuthVerificationCode {
  id           String          @id @default(cuid())
  userId       String?         @map("user_id")
  channel      AuthCodeChannel
  purpose      AuthCodePurpose
  target       String
  codeHash     String          @map("code_hash")
  expiresAt    DateTime        @map("expires_at")
  consumedAt   DateTime?       @map("consumed_at")
  attemptCount Int             @default(0) @map("attempt_count")
  sentAt       DateTime        @default(now()) @map("sent_at")
  createdAt    DateTime        @default(now()) @map("created_at")
  updatedAt    DateTime        @updatedAt @map("updated_at")

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([channel, purpose, target, sentAt])
  @@index([target, consumedAt, expiresAt])
  @@index([userId, purpose])
  @@map("auth_verification_codes")
}

// MARK: - 会话
model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

// MARK: - 验证令牌
model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// MARK: - 认证器
model Authenticator {
  credentialID         String  @map("credential_id")
  userId               String  @map("user_id")
  providerAccountId    String  @map("provider_account_id")
  credentialPublicKey  String  @map("credential_public_key")
  counter              Int
  credentialDeviceType String  @map("credential_device_type")
  credentialBackedUp   Boolean @map("credential_backed_up")
  transports           String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, credentialID])
  @@unique([credentialID])
  @@map("authenticators")
}

// MARK: - 用户角色
model UserRole {
  id        String       @id @default(cuid())
  userId    String       @map("user_id")
  role      PlatformRole
  isPrimary Boolean      @default(false) @map("is_primary")
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, role])
  @@index([role, isPrimary])
  @@map("user_roles")
}

// MARK: - 科目
model Subject {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  description String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  teacherSubjects TeacherSubject[]
  bookings        Booking[]

  @@index([name])
  @@map("subjects")
}

// MARK: - 教师资料
model TeacherProfile {
  id                    String                    @id @default(cuid())
  userId                String                    @unique @map("user_id")
  displayName           String                    @map("display_name")
  bio                   String?
  employmentType        TeacherEmploymentType?    @map("employment_type")
  verificationStatus    TeacherVerificationStatus @default(PENDING) @map("verification_status")
  baseHourlyRate        Decimal                   @default(0) @map("base_hourly_rate") @db.Decimal(10, 2)
  serviceRadiusKm       Int                       @default(10) @map("service_radius_km")
  acceptTrial           Boolean                   @default(true) @map("accept_trial")
  maxTravelMinutes      Int                       @default(60) @map("max_travel_minutes")
  timezone              String                    @default("Asia/Shanghai")
  ratingAvg             Decimal                   @default(0) @map("rating_avg") @db.Decimal(4, 2)
  ratingCount           Int                       @default(0) @map("rating_count")
  totalCompletedLessons Int                       @default(0) @map("total_completed_lessons")
  agreementAcceptedAt   DateTime?                 @map("agreement_accepted_at")
  agreementVersion      String?                   @map("agreement_version")
  interviewedAt         DateTime?                 @map("interviewed_at")
  interviewNotes        String?                   @map("interview_notes")
  onboardingCompletedAt DateTime?                 @map("onboarding_completed_at")
  createdAt             DateTime                  @default(now()) @map("created_at")
  updatedAt             DateTime                  @updatedAt @map("updated_at")

  user               User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  subjects           TeacherSubject[]
  serviceAreas       TeacherServiceArea[]
  availabilityRules  TeacherAvailabilityRule[]
  availabilityBlocks TeacherAvailabilityBlock[]
  credentials        TeacherCredential[]
  bookings           Booking[]
  lessons            Lesson[]
  reviews            TeacherReview[]
  payoutAccounts     TeacherPayoutAccount[]
  payouts            Payout[]

  @@index([verificationStatus])
  @@index([employmentType, verificationStatus])
  @@map("teacher_profiles")
}

// MARK: - 教师科目
model TeacherSubject {
  id               String   @id @default(cuid())
  teacherProfileId String   @map("teacher_profile_id")
  subjectId        String   @map("subject_id")
  hourlyRate       Decimal  @map("hourly_rate") @db.Decimal(10, 2)
  trialRate        Decimal? @map("trial_rate") @db.Decimal(10, 2)
  experienceYears  Int      @default(0) @map("experience_years")
  isActive         Boolean  @default(true) @map("is_active")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  teacherProfile TeacherProfile @relation(fields: [teacherProfileId], references: [id], onDelete: Cascade)
  subject        Subject        @relation(fields: [subjectId], references: [id], onDelete: Restrict)

  @@unique([teacherProfileId, subjectId])
  @@index([subjectId, isActive])
  @@index([teacherProfileId, isActive])
  @@map("teacher_subjects")
}

// MARK: - 教师服务区域
model TeacherServiceArea {
  id               String   @id @default(cuid())
  teacherProfileId String   @map("teacher_profile_id")
  province         String
  city             String
  district         String
  radiusKm         Int      @default(10) @map("radius_km")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  teacherProfile TeacherProfile @relation(fields: [teacherProfileId], references: [id], onDelete: Cascade)

  @@unique([teacherProfileId, province, city, district])
  @@index([city, district])
  @@map("teacher_service_areas")
}

// MARK: - 教师可用性规则
model TeacherAvailabilityRule {
  id                  String    @id @default(cuid())
  teacherProfileId    String    @map("teacher_profile_id")
  weekday             Weekday
  startMinute         Int       @map("start_minute")
  endMinute           Int       @map("end_minute")
  slotDurationMinutes Int       @default(60) @map("slot_duration_minutes")
  bufferMinutes       Int       @default(0) @map("buffer_minutes")
  isActive            Boolean   @default(true) @map("is_active")
  effectiveFrom       DateTime? @map("effective_from") @db.Date
  effectiveTo         DateTime? @map("effective_to") @db.Date
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  teacherProfile TeacherProfile @relation(fields: [teacherProfileId], references: [id], onDelete: Cascade)

  @@index([teacherProfileId, weekday, isActive])
  @@map("teacher_availability_rules")
}

// MARK: - 教师可用性块
model TeacherAvailabilityBlock {
  id               String   @id @default(cuid())
  teacherProfileId String   @map("teacher_profile_id")
  startAt          DateTime @map("start_at")
  endAt            DateTime @map("end_at")
  reason           String?
  createdByUserId  String?  @map("created_by_user_id")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  teacherProfile TeacherProfile @relation(fields: [teacherProfileId], references: [id], onDelete: Cascade)
  createdByUser  User?          @relation("AvailabilityBlockCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([teacherProfileId, startAt, endAt])
  @@index([createdByUserId])
  @@map("teacher_availability_blocks")
}

// MARK: - 教师凭证
model TeacherCredential {
  id               String               @id @default(cuid())
  teacherProfileId String               @map("teacher_profile_id")
  credentialType   CredentialType       @map("credential_type")
  name             String
  issuedBy         String?              @map("issued_by")
  issuedAt         DateTime?            @map("issued_at") @db.Date
  expiresAt        DateTime?            @map("expires_at") @db.Date
  fileUrl          String               @map("file_url")
  reviewStatus     DocumentReviewStatus @default(PENDING) @map("review_status")
  reviewNotes      String?              @map("review_notes")
  reviewedByUserId String?              @map("reviewed_by_user_id")
  reviewedAt       DateTime?            @map("reviewed_at")
  createdAt        DateTime             @default(now()) @map("created_at")
  updatedAt        DateTime             @updatedAt @map("updated_at")

  teacherProfile TeacherProfile @relation(fields: [teacherProfileId], references: [id], onDelete: Cascade)
  reviewedByUser User?          @relation("CredentialReviewedBy", fields: [reviewedByUserId], references: [id], onDelete: SetNull)

  @@index([teacherProfileId, reviewStatus])
  @@index([reviewedByUserId])
  @@map("teacher_credentials")
}

// MARK: - 学生资料
model StudentProfile {
  id                    String      @id @default(cuid())
  userId                String?     @unique @map("user_id")
  displayName           String      @map("display_name")
  gradeLevel            GradeLevel? @map("grade_level")
  dateOfBirth           DateTime?   @map("date_of_birth") @db.Date
  schoolName            String?     @map("school_name")
  learningGoals         String?     @map("learning_goals")
  specialNeeds          String?     @map("special_needs")
  timezone              String      @default("Asia/Shanghai")
  onboardingCompletedAt DateTime?   @map("onboarding_completed_at")
  createdAt             DateTime    @default(now()) @map("created_at")
  updatedAt             DateTime    @updatedAt @map("updated_at")

  user         User?             @relation(fields: [userId], references: [id], onDelete: Cascade)
  guardians    StudentGuardian[]
  bookings     Booking[]
  lessons      Lesson[]
  reviewsGiven TeacherReview[]

  @@index([gradeLevel])
  @@map("student_profiles")
}

// MARK: - 监护人资料
model GuardianProfile {
  id                      String    @id @default(cuid())
  userId                  String    @unique @map("user_id")
  displayName             String    @map("display_name")
  phone                   String?
  emergencyContactName    String?   @map("emergency_contact_name")
  emergencyContactPhone   String?   @map("emergency_contact_phone")
  defaultServiceAddressId String?   @map("default_service_address_id")
  onboardingCompletedAt   DateTime? @map("onboarding_completed_at")
  createdAt               DateTime  @default(now()) @map("created_at")
  updatedAt               DateTime  @updatedAt @map("updated_at")

  user                  User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  students              StudentGuardian[]
  bookings              Booking[]
  reviews               TeacherReview[]
  defaultServiceAddress Address?          @relation("GuardianDefaultServiceAddress", fields: [defaultServiceAddressId], references: [id], onDelete: SetNull)

  @@index([defaultServiceAddressId])
  @@map("guardian_profiles")
}

// MARK: - 学生监护人关系
model StudentGuardian {
  id                String           @id @default(cuid())
  studentProfileId  String           @map("student_profile_id")
  guardianProfileId String           @map("guardian_profile_id")
  relation          GuardianRelation
  isPrimary         Boolean          @default(false) @map("is_primary")
  canBook           Boolean          @default(true) @map("can_book")
  canViewRecords    Boolean          @default(true) @map("can_view_records")
  createdAt         DateTime         @default(now()) @map("created_at")
  updatedAt         DateTime         @updatedAt @map("updated_at")

  studentProfile  StudentProfile  @relation(fields: [studentProfileId], references: [id], onDelete: Cascade)
  guardianProfile GuardianProfile @relation(fields: [guardianProfileId], references: [id], onDelete: Cascade)

  @@unique([studentProfileId, guardianProfileId])
  @@index([guardianProfileId, canBook])
  @@map("student_guardians")
}

// MARK: - 地址
model Address {
  id           String   @id @default(cuid())
  userId       String   @map("user_id")
  label        String?
  contactName  String   @map("contact_name")
  contactPhone String   @map("contact_phone")
  country      String   @default("CN")
  province     String
  city         String
  district     String
  street       String
  building     String?
  latitude     Decimal? @db.Decimal(10, 7)
  longitude    Decimal? @db.Decimal(10, 7)
  isDefault    Boolean  @default(false) @map("is_default")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user               User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  guardianDefaultFor GuardianProfile[] @relation("GuardianDefaultServiceAddress")
  bookings           Booking[]         @relation("BookingServiceAddress")

  @@index([userId, isDefault])
  @@index([city, district])
  @@map("addresses")
}

// MARK: - 实名认证会话
model RealNameVerificationSession {
  id            String    @id @default(cuid())
  userId        String    @map("user_id")
  provider      String
  status        String    @default("PENDING")
  ticket        String?   @unique
  startUrl      String?   @map("start_url")
  resultPayload Json?     @map("result_payload")
  verifiedAt    DateTime? @map("verified_at")
  expiresAt     DateTime? @map("expires_at")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@map("real_name_verification_sessions")
}

// MARK: - 预约
model Booking {
  id                    String                     @id @default(cuid())
  bookingNo             String                     @unique @map("booking_no")
  teacherProfileId      String                     @map("teacher_profile_id")
  studentProfileId      String                     @map("student_profile_id")
  guardianProfileId     String?                    @map("guardian_profile_id")
  subjectId             String                     @map("subject_id")
  serviceAddressId      String                     @map("service_address_id")
  startAt               DateTime                   @map("start_at")
  endAt                 DateTime                   @map("end_at")
  timezone              String                     @default("Asia/Shanghai")
  status                BookingStatus              @default(PENDING_ACCEPTANCE)
  cancellationReason    BookingCancellationReason? @map("cancellation_reason")
  cancelledAt           DateTime?                  @map("cancelled_at")
  cancelledByUserId     String?                    @map("cancelled_by_user_id")
  isTrial               Boolean                    @default(false) @map("is_trial")
  teacherAcceptedAt     DateTime?                  @map("teacher_accepted_at")
  guardianConfirmedAt   DateTime?                  @map("guardian_confirmed_at")
  hourlyRate            Decimal                    @map("hourly_rate") @db.Decimal(10, 2)
  durationMinutes       Int                        @map("duration_minutes")
  subtotalAmount        Decimal                    @map("subtotal_amount") @db.Decimal(12, 2)
  discountAmount        Decimal                    @default(0) @map("discount_amount") @db.Decimal(12, 2)
  platformFeeAmount     Decimal                    @default(0) @map("platform_fee_amount") @db.Decimal(12, 2)
  travelFeeAmount       Decimal                    @default(0) @map("travel_fee_amount") @db.Decimal(12, 2)
  totalAmount           Decimal                    @map("total_amount") @db.Decimal(12, 2)
  currency              Currency                   @default(CNY)
  paymentStatus         PaymentStatus              @default(UNPAID) @map("payment_status")
  paymentDueAt          DateTime?                  @map("payment_due_at")
  completionStatus      BookingCompletionStatus    @default(PENDING_TEACHER_RECORD) @map("completion_status")
  completionConfirmedAt DateTime?                  @map("completion_confirmed_at")
  exceptionStatus       BookingExceptionStatus     @default(NONE) @map("exception_status")
  settlementReadiness   SettlementReadiness        @default(NOT_READY) @map("settlement_readiness")
  statusRemark          String?                    @map("status_remark")
  planSummary           String?                    @map("plan_summary")
  notes                 String?
  createdAt             DateTime                   @default(now()) @map("created_at")
  updatedAt             DateTime                   @updatedAt @map("updated_at")

  teacherProfile     TeacherProfile         @relation(fields: [teacherProfileId], references: [id], onDelete: Restrict)
  studentProfile     StudentProfile         @relation(fields: [studentProfileId], references: [id], onDelete: Restrict)
  guardianProfile    GuardianProfile?       @relation(fields: [guardianProfileId], references: [id], onDelete: SetNull)
  subject            Subject                @relation(fields: [subjectId], references: [id], onDelete: Restrict)
  serviceAddress     Address                @relation("BookingServiceAddress", fields: [serviceAddressId], references: [id], onDelete: Restrict)
  cancelledByUser    User?                  @relation("BookingCancelledBy", fields: [cancelledByUserId], references: [id], onDelete: SetNull)
  lesson             Lesson?
  paymentIntent      PaymentIntent?
  review             TeacherReview?
  rescheduleRequests RescheduleRequest[]
  exceptionCases     BookingExceptionCase[]
  walletTransactions WalletTransaction[]

  @@index([teacherProfileId, startAt, status])
  @@index([studentProfileId, startAt])
  @@index([guardianProfileId, startAt])
  @@index([status, paymentStatus, startAt])
  @@index([subjectId, status])
  @@index([serviceAddressId])
  @@index([cancelledByUserId])
  @@map("bookings")
}

// MARK: - 预约占位
model BookingHold {
  id                String            @id @default(cuid())
  teacherProfileId  String            @map("teacher_profile_id")
  studentProfileId  String            @map("student_profile_id")
  guardianProfileId String?           @map("guardian_profile_id")
  subjectId         String            @map("subject_id")
  serviceAddressId  String            @map("service_address_id")
  startAt           DateTime          @map("start_at")
  endAt             DateTime          @map("end_at")
  timezone          String            @default("Asia/Shanghai")
  status            BookingHoldStatus @default(ACTIVE)
  expiresAt         DateTime          @map("expires_at")
  createdByUserId   String            @map("created_by_user_id")
  createdAt         DateTime          @default(now()) @map("created_at")
  updatedAt         DateTime          @updatedAt @map("updated_at")

  @@index([teacherProfileId, startAt, endAt, status])
  @@index([createdByUserId, status, expiresAt])
  @@index([guardianProfileId, status])
  @@map("booking_holds")
}

// MARK: - 改约请求
model RescheduleRequest {
  id                String                  @id @default(cuid())
  bookingId         String                  @map("booking_id")
  initiatorRole     PlatformRole            @map("initiator_role")
  initiatorUserId   String                  @map("initiator_user_id")
  proposedStartAt   DateTime                @map("proposed_start_at")
  proposedEndAt     DateTime                @map("proposed_end_at")
  reason            String?
  status            RescheduleRequestStatus @default(PENDING)
  respondedAt       DateTime?               @map("responded_at")
  respondedByUserId String?                 @map("responded_by_user_id")
  createdAt         DateTime                @default(now()) @map("created_at")
  updatedAt         DateTime                @updatedAt @map("updated_at")

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@index([bookingId, status, createdAt])
  @@index([initiatorUserId, status, createdAt])
  @@map("reschedule_requests")
}

// MARK: - 课程
model Lesson {
  id                  String                 @id @default(cuid())
  bookingId           String                 @unique @map("booking_id")
  teacherProfileId    String                 @map("teacher_profile_id")
  studentProfileId    String                 @map("student_profile_id")
  attendanceStatus    LessonAttendanceStatus @default(SCHEDULED) @map("attendance_status")
  arrivalConfirmedAt  DateTime?              @map("arrival_confirmed_at")
  arrivalLatitude     Decimal?               @map("arrival_latitude") @db.Decimal(10, 7)
  arrivalLongitude    Decimal?               @map("arrival_longitude") @db.Decimal(10, 7)
  arrivalAddress      String?                @map("arrival_address")
  arrivalNote         String?                @map("arrival_note")
  checkInAt           DateTime?              @map("check_in_at")
  checkInLatitude     Decimal?               @map("check_in_latitude") @db.Decimal(10, 7)
  checkInLongitude    Decimal?               @map("check_in_longitude") @db.Decimal(10, 7)
  checkInAddress      String?                @map("check_in_address")
  startedAt           DateTime?              @map("started_at")
  endedAt             DateTime?              @map("ended_at")
  checkOutAt          DateTime?              @map("check_out_at")
  checkOutLatitude    Decimal?               @map("check_out_latitude") @db.Decimal(10, 7)
  checkOutLongitude   Decimal?               @map("check_out_longitude") @db.Decimal(10, 7)
  checkOutAddress     String?                @map("check_out_address")
  teacherSummary      String?                @map("teacher_summary")
  homework            String?
  outcomeVideoUrl     String?                @map("outcome_video_url")
  feedbackSubmittedAt DateTime?              @map("feedback_submitted_at")
  guardianFeedback    String?                @map("guardian_feedback")
  createdAt           DateTime               @default(now()) @map("created_at")
  updatedAt           DateTime               @updatedAt @map("updated_at")

  booking        Booking          @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  teacherProfile TeacherProfile   @relation(fields: [teacherProfileId], references: [id], onDelete: Restrict)
  studentProfile StudentProfile   @relation(fields: [studentProfileId], references: [id], onDelete: Restrict)
  evidences      LessonEvidence[]

  @@index([teacherProfileId, attendanceStatus, startedAt])
  @@index([studentProfileId, attendanceStatus, startedAt])
  @@map("lessons")
}

// MARK: - 预约异常工单
model BookingExceptionCase {
  id                 String                     @id @default(cuid())
  bookingId          String                     @map("booking_id")
  exceptionType      BookingExceptionType       @map("exception_type")
  status             BookingExceptionCaseStatus @default(OPEN)
  responsibilityType ResponsibilityType         @default(UNKNOWN) @map("responsibility_type")
  summary            String
  resolution         String?
  metadata           Json?
  createdByUserId    String?                    @map("created_by_user_id")
  resolvedByUserId   String?                    @map("resolved_by_user_id")
  createdAt          DateTime                   @default(now()) @map("created_at")
  updatedAt          DateTime                   @updatedAt @map("updated_at")

  booking Booking @relation(fields: [bookingId], references: [id], onDelete: Cascade)

  @@unique([bookingId, exceptionType])
  @@index([status, createdAt])
  @@index([responsibilityType, status])
  @@map("booking_exception_cases")
}

// MARK: - 课程证据
model LessonEvidence {
  id               String             @id @default(cuid())
  lessonId         String             @map("lesson_id")
  type             LessonEvidenceType
  url              String
  note             String?
  uploadedByUserId String             @map("uploaded_by_user_id")
  uploadedAt       DateTime           @default(now()) @map("uploaded_at")
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @updatedAt @map("updated_at")

  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@index([lessonId, type, uploadedAt])
  @@index([uploadedByUserId, uploadedAt])
  @@map("lesson_evidences")
}

// MARK: - 教师评价
model TeacherReview {
  id                       String   @id @default(cuid())
  bookingId                String   @unique @map("booking_id")
  teacherProfileId         String   @map("teacher_profile_id")
  studentProfileId         String   @map("student_profile_id")
  guardianProfileId        String?  @map("guardian_profile_id")
  rating                   Int
  lessonQualityRating      Int?     @map("lesson_quality_rating")
  teacherPerformanceRating Int?     @map("teacher_performance_rating")
  comment                  String?
  improvementNotes         String?  @map("improvement_notes")
  tags                     Json?
  createdAt                DateTime @default(now()) @map("created_at")
  updatedAt                DateTime @updatedAt @map("updated_at")

  booking         Booking          @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  teacherProfile  TeacherProfile   @relation(fields: [teacherProfileId], references: [id], onDelete: Restrict)
  studentProfile  StudentProfile   @relation(fields: [studentProfileId], references: [id], onDelete: Restrict)
  guardianProfile GuardianProfile? @relation(fields: [guardianProfileId], references: [id], onDelete: SetNull)

  @@index([teacherProfileId, createdAt])
  @@index([studentProfileId, createdAt])
  @@index([guardianProfileId, createdAt])
  @@map("teacher_reviews")
}

// MARK: - 钱包
model Wallet {
  id               String       @id @default(cuid())
  ownerUserId      String       @unique @map("owner_user_id")
  currency         Currency     @default(CNY)
  availableBalance Decimal      @default(0) @map("available_balance") @db.Decimal(12, 2)
  lockedBalance    Decimal      @default(0) @map("locked_balance") @db.Decimal(12, 2)
  status           WalletStatus @default(ACTIVE)
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")

  ownerUser      User                @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  transactions   WalletTransaction[]
  paymentIntents PaymentIntent[]
  payouts        Payout[]

  @@index([status])
  @@map("wallets")
}

// MARK: - 支付意图
model PaymentIntent {
  id                String              @id @default(cuid())
  bookingId         String              @unique @map("booking_id")
  payerUserId       String              @map("payer_user_id")
  walletId          String?             @map("wallet_id")
  amount            Decimal             @db.Decimal(12, 2)
  currency          Currency            @default(CNY)
  status            PaymentIntentStatus @default(REQUIRES_PAYMENT)
  provider          String?
  providerPaymentId String?             @unique @map("provider_payment_id")
  expiresAt         DateTime?           @map("expires_at")
  providerPrepayId  String?             @map("provider_prepay_id")
  prepayExpiresAt   DateTime?           @map("prepay_expires_at")
  providerMetadata  Json?               @map("provider_metadata")
  lastNotifiedAt    DateTime?           @map("last_notified_at")
  capturedAt        DateTime?           @map("captured_at")
  failedReason      String?             @map("failed_reason")
  createdAt         DateTime            @default(now()) @map("created_at")
  updatedAt         DateTime            @updatedAt @map("updated_at")

  booking        Booking                @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  payerUser      User                   @relation("PaymentPayer", fields: [payerUserId], references: [id], onDelete: Restrict)
  wallet         Wallet?                @relation(fields: [walletId], references: [id], onDelete: SetNull)
  transactions   WalletTransaction[]
  providerEvents PaymentProviderEvent[]

  @@index([payerUserId, status, createdAt])
  @@index([walletId])
  @@map("payment_intents")
}

// MARK: - 支付渠道事件
model PaymentProviderEvent {
  id              String    @id @default(cuid())
  provider        String
  eventId         String    @map("event_id")
  paymentIntentId String?   @map("payment_intent_id")
  headersDigest   String    @map("headers_digest")
  payload         Json
  receivedAt      DateTime  @default(now()) @map("received_at")
  processedAt     DateTime? @map("processed_at")
  processResult   String?   @map("process_result")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  paymentIntent PaymentIntent? @relation(fields: [paymentIntentId], references: [id], onDelete: SetNull)

  @@unique([provider, eventId])
  @@index([paymentIntentId, receivedAt])
  @@index([provider, receivedAt])
  @@map("payment_provider_events")
}

// MARK: - 教师提现账户
model TeacherPayoutAccount {
  id               String            @id @default(cuid())
  teacherProfileId String            @map("teacher_profile_id")
  accountType      PayoutAccountType @map("account_type")
  accountName      String            @map("account_name")
  accountNoMasked  String            @map("account_no_masked")
  accountToken     String            @map("account_token")
  isDefault        Boolean           @default(false) @map("is_default")
  isVerified       Boolean           @default(false) @map("is_verified")
  createdAt        DateTime          @default(now()) @map("created_at")
  updatedAt        DateTime          @updatedAt @map("updated_at")

  teacherProfile TeacherProfile @relation(fields: [teacherProfileId], references: [id], onDelete: Cascade)
  payouts        Payout[]

  @@unique([teacherProfileId, accountToken])
  @@index([teacherProfileId, isDefault])
  @@map("teacher_payout_accounts")
}

// MARK: - 提现
model Payout {
  id               String       @id @default(cuid())
  teacherProfileId String       @map("teacher_profile_id")
  walletId         String?      @map("wallet_id")
  payoutAccountId  String       @map("payout_account_id")
  amount           Decimal      @db.Decimal(12, 2)
  currency         Currency     @default(CNY)
  status           PayoutStatus @default(PENDING)
  requestedAt      DateTime     @default(now()) @map("requested_at")
  processedAt      DateTime?    @map("processed_at")
  failureReason    String?      @map("failure_reason")
  transactionId    String?      @unique @map("transaction_id")
  createdAt        DateTime     @default(now()) @map("created_at")
  updatedAt        DateTime     @updatedAt @map("updated_at")

  teacherProfile     TeacherProfile       @relation(fields: [teacherProfileId], references: [id], onDelete: Restrict)
  wallet             Wallet?              @relation(fields: [walletId], references: [id], onDelete: SetNull)
  payoutAccount      TeacherPayoutAccount @relation(fields: [payoutAccountId], references: [id], onDelete: Restrict)
  walletTransactions WalletTransaction[]

  @@index([teacherProfileId, status, requestedAt])
  @@index([walletId])
  @@index([payoutAccountId])
  @@map("payouts")
}

// MARK: - 钱包交易
model WalletTransaction {
  id              String                   @id @default(cuid())
  walletId        String                   @map("wallet_id")
  type            WalletTransactionType
  status          LedgerStatus             @default(PENDING)
  direction       TransactionDirection
  amount          Decimal                  @db.Decimal(12, 2)
  balanceAfter    Decimal?                 @map("balance_after") @db.Decimal(12, 2)
  referenceType   TransactionReferenceType @default(MANUAL) @map("reference_type")
  referenceId     String?                  @map("reference_id")
  bookingId       String?                  @map("booking_id")
  paymentIntentId String?                  @map("payment_intent_id")
  payoutId        String?                  @map("payout_id")
  metadata        Json?
  occurredAt      DateTime                 @default(now()) @map("occurred_at")
  createdByUserId String?                  @map("created_by_user_id")
  createdAt       DateTime                 @default(now()) @map("created_at")
  updatedAt       DateTime                 @updatedAt @map("updated_at")

  wallet        Wallet         @relation(fields: [walletId], references: [id], onDelete: Cascade)
  booking       Booking?       @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  paymentIntent PaymentIntent? @relation(fields: [paymentIntentId], references: [id], onDelete: SetNull)
  payout        Payout?        @relation(fields: [payoutId], references: [id], onDelete: SetNull)
  createdByUser User?          @relation("TxnCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([walletId, occurredAt])
  @@index([referenceType, referenceId])
  @@index([bookingId])
  @@index([paymentIntentId])
  @@index([payoutId])
  @@index([status, occurredAt])
  @@index([createdByUserId])
  @@map("wallet_transactions")
}

// MARK: - 管理员审计日志
model AdminAuditLog {
  id          String   @id @default(cuid())
  actorUserId String   @map("actor_user_id")
  action      String
  targetType  String   @map("target_type")
  targetId    String?  @map("target_id")
  ipAddress   String?  @map("ip_address")
  userAgent   String?  @map("user_agent")
  payload     Json?
  createdAt   DateTime @default(now()) @map("created_at")

  actorUser User @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: Restrict)

  @@index([actorUserId, createdAt])
  @@index([targetType, targetId])
  @@index([action, createdAt])
  @@map("admin_audit_logs")
}
