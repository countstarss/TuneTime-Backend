# Supabase project
SUPABASE_PROJECT_REF=""
SUPABASE_DB_PASSWORD="YOUR-PASSWORD"
SUPABASE_DB_PASSWORD_ENCODED="YOUR-URL-ENCODED-PASSWORD"
SUPABASE_POOLER_HOST=""

# Prisma runtime (pooling)
DATABASE_URL=""

# Prisma migration/direct path
DIRECT_URL=""

# Application auth (custom/Auth.js style JWT)
AUTH_JWT_SECRET="replace-with-a-strong-secret-at-least-32-characters"
AUTH_JWT_ISSUER=""
AUTH_JWT_AUDIENCE=""
AUTH_JWKS_URL=""
AUTH_JWT_EXPIRES_IN="7d"
AUTH_CODE_SECRET=""
AUTH_CODE_TTL_SECONDS="600"
AUTH_CODE_RESEND_COOLDOWN_SECONDS="60"
AUTH_CODE_MAX_ATTEMPTS="5"

# WeChat App OAuth
WECHAT_APP_APP_ID=""
WECHAT_APP_SECRET=""

# WeChat Mini Program login
WECHAT_MINIAPP_APP_ID=""
WECHAT_MINIAPP_SECRET=""

# WeChat Pay
PAYMENT_ENABLED="true"
WECHAT_PAY_MCH_ID=""
WECHAT_PAY_MCH_CERT_SERIAL_NO=""
WECHAT_PAY_PLATFORM_SERIAL_NO=""
WECHAT_PAY_API_V3_KEY=""
WECHAT_PAY_PRIVATE_KEY_PEM=""
WECHAT_PAY_PLATFORM_PUBLIC_KEY_PEM=""
WECHAT_PAY_NOTIFY_URL=""
WECHAT_PAY_REQUEST_TIMEOUT_MS="5000"

# Tencent Cloud SMS (optional in local dev; falls back to console logging when omitted)
TENCENT_SMS_SECRET_ID=""
TENCENT_SMS_SECRET_KEY=""
TENCENT_SMS_REGION="ap-guangzhou"
TENCENT_SMS_SDK_APP_ID=""
TENCENT_SMS_SIGN_NAME=""
TENCENT_SMS_TEMPLATE_LOGIN=""
TENCENT_SMS_TEMPLATE_PHONE_BIND=""
ADMIN_CORS_ORIGIN="http://localhost:3000"
